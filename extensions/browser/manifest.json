{
  "manifest_version": 3,
  "name": "Vulture Browser Relay",
  "version": "0.1.0",
  "permissions": [
    "debugger",
    "tabs",
    "tabGroups",
    "windows",
    "scripting",
    "storage",
    "alarms",
    "notifications"
  ],
  "host_permissions": ["<all_urls>"],
  "background": {
    "service_worker": "src/background.js",
    "type": "module"
  },
  "action": {
    "default_popup": "src/popup.html"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["src/content.js"],
      "run_at": "document_idle"
    }
  ]
}
